# ============================================
# Budget Calculator — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ============================================

# --- Aplicación ---
SECRET_KEY=cambia-esto-por-una-clave-segura-de-32-caracteres
ENVIRONMENT=development
DEBUG=true
APP_URL=http://localhost:5173

# --- Base de datos (vacío = SQLite local) ---
# DATABASE_URL=postgresql://usuario:password@host:5432/budget

# --- Proveedor LLM: "azure" o "openai" ---
LLM_PROVIDER=azure

# Azure AI Foundry (si LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini

# OpenAI directo (si LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- Email de sistema (reset contraseña) via Resend ---
RESEND_API_KEY=
EMAIL_FROM_SYSTEM=sistema@tudominio.com

# --- Email de presupuestos via SMTP (Resend SMTP relay u otro) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_TLS=false
EMAIL_FROM_BUDGETS=presupuestos@tudominio.com
EMAIL_FROM_NAME=ISI Obras y Servicios

# --- Datos de empresa (aparecen en emails y PDF) ---
EMPRESA_NOMBRE=ISI Obras y Servicios
EMPRESA_TELEFONO=+34 600 000 000
EMPRESA_EMAIL=info@tudominio.com
EMPRESA_WEB=https://tudominio.com

# --- Reglas de negocio (defaults razonables, no tocar sin motivo) ---
# IVA_GENERAL=21
# MARKUP_PARTIDAS_INDIVIDUALES=15
# REDONDEO_ALZA=5
# VALIDEZ_PRESUPUESTO_DIAS=30
