{
	admin off
	auto_https off
}

:{$PORT:3000} {
	root * /srv
	encode gzip

	# Proxy API al backend (Railway private networking)
	handle /api/* {
		reverse_proxy {$BACKEND_URL:http://localhost:8000}
	}

	handle /health {
		respond "OK" 200
	}

	# SPA: catch-all para rutas del frontend
	handle {
		try_files {path} /index.html
		file_server
	}
}

